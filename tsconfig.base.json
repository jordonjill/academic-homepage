{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "paths": {
      "@academic-homepage/shared": [
        "./packages/shared/src/index.ts"
      ],
      "@academic-homepage/shared/local-data": [
        "./packages/shared/src/local-data.ts"
      ]
    }
  }
}
